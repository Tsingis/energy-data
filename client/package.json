{
  "name": "energy-data",
  "type": "module",
  "engineStrict": true,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "npm@11.17.0",
  "scripts": {
    "predev": "node check-packages.js",
    "dev": "vite --config ./vite.config.ts --open",
    "dev:check": "vite --config ./vite.config.ts --open -- --use-checker",
    "preview": "vite preview --config ./vite.config.ts",
    "test": "vitest --config vitest.config.ts",
    "playwright:setup": "npx playwright install --with-deps",
    "playwright": "npx playwright test --config=playwright.config.ts",
    "playwright:update": "npx playwright test --config=playwright.config.ts --update-snapshots",
    "audit": "npm audit --audit-level low",
    "eslint": "eslint . --config ./eslint.config.js",
    "eslint:fix": "eslint . --config ./eslint.config.js --fix",
    "prettier": "prettier --check '**/*.{js,ts,vue,css,html}'",
    "prettier:fix": "prettier --write '**/*.{js,ts,vue,css,html}'",
    "typecheck": "vue-tsc --noEmit -p ./tsconfig.json",
    "build": "vite --config ./vite.config.ts build"
  },
  "dependencies": {
    "@phosphor-icons/vue": "^2.2.1",
    "chart.js": "^4.5.1",
    "chartjs-adapter-date-fns": "^3.0.0",
    "chartjs-plugin-annotation": "^3.1.0",
    "vue": "^3.5.38"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-playwright": "^2.10.4",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-checker": "^0.14.4",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.5"
  },
  "overrides": {
    "minimatch": "^10.2.3"
  }
}
